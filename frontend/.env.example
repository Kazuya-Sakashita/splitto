####################################
# Clerk Authentication (Frontend)
####################################

# Clerkの公開キー（フロントエンドで使用）
# Clerk Dashboard > API Keys から取得してください
# 本番では pk_live_xxx、開発では pk_test_xxx を使用します
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Clerkのシークレットキー（サーバーサイドで使用）
# ※ Git管理せず、各自の .env.local に実際の値を設定してください
# Clerk Dashboard > API Keys から取得します
CLERK_SECRET_KEY=sk_test_xxx

####################################
# Clerk Routing Settings
####################################

# サインインページのパス
# App Router の /sign-in に対応
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

# サインアップページのパス
# App Router の /sign-up に対応
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

####################################
# Notes
####################################
# - このファイルは例示用です（.env.example）
# - 実際の値は frontend/.env.local に設定してください
# - .env.local は Git にコミットしないでください
